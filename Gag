local function collectBillboards()
	local found, roots = {}, { PlayerGui }
	pcall(function() table.insert(roots, CoreGui) end)
	for _, root in ipairs(roots) do
		if root then
			for _, d in ipairs(root:GetDescendants()) do
				if d.Name == "Billboard_UI" then table.insert(found, d) end
			end
		end
	end
	return found
end

local function findOptionButtonByText(needle)
	needle = tostring(needle):lower()
	for _, billboard in ipairs(collectBillboards()) do
		for _, opt in ipairs(billboard:GetDescendants()) do
			if opt.Name == "Option_UI" and opt:IsA("GuiObject") then
				local te, btn
				for _, d in ipairs(opt:GetDescendants()) do
					if not te  and d.Name == "Text_Element" and d:IsA("TextLabel") then te  = d end
					if not btn and (d:IsA("ImageButton") or d:IsA("TextButton")) then btn = d end
					if te and btn then break end
				end
				if te and btn and tostring(te.Text or ""):lower():find(needle, 1, true) then
					return btn, te, opt
				end
			end
		end
	end
end

local function waitForOption(needle, timeout)
	timeout = timeout or 4
	local t0 = tick()
	while tick() - t0 < timeout do
		local b, te, opt = findOptionButtonByText(needle)
		if b then return b, te, opt end
		task.wait(0.08)
	end
end

local function clickGuiButton(btn)
	if not btn or not btn.Parent then return false end
	local pos = btn.AbsolutePosition
	local sz  = btn.AbsoluteSize
	local cx  = math.floor(pos.X + sz.X * 0.5)
	local cy  = math.floor(pos.Y + sz.Y * 0.5)
	pcall(function()
		VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, true,  game, 0)
		task.wait(0.02)
		VirtualInputManager:SendMouseButtonEvent(cx, cy, 0, false, game, 0)
	end)
	task.wait(0.02)
	pcall(function()
		VirtualInputManager:SendTouchEvent(1, 1, cx, cy)
		task.wait(0.02)
		VirtualInputManager:SendTouchEvent(1, 2, cx, cy)
		VirtualInputManager:SendTouchEvent(1, 3, cx, cy)
	end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Down) end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Up)   end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Click) end end)
	pcall(function() if firesignal then firesignal(btn.Activated)         end end)
	pcall(function() btn.MouseButton1Click:Fire() end)
	pcall(function() btn.Activated:Fire(Enum.UserInputType.MouseButton1) end)
	return true
end

