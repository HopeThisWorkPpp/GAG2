local function normalizeName(s) return (tostring(s or ""):lower():gsub("[%s_%-:'%.]", "")) end
local PET_LOOKUP, SEED_LOOKUP = {}, {}
for k in pairs(PET_RARITY)  do PET_LOOKUP[normalizeName(k)]  = k end
for k in pairs(SEED_RARITY) do SEED_LOOKUP[normalizeName(k)] = k end

local function stripInvPrefix(name)
	local s = tostring(name or "")
	for _,p in ipairs({"^Inv_Pets:","^Inv_Seeds:","^Inv_Crates:","^Inv_Mushrooms:","^Inv_Sprinklers:","^Inv_WateringCans:"}) do
		s = s:gsub(p,"")
	end
	return s
end

local function resolveItemName(tool)
	local clean = stripInvPrefix(tool.Name)
	local key = normalizeName(clean)
	if PET_LOOKUP[key]  then return PET_LOOKUP[key],  "Pets"  end
	if SEED_LOOKUP[key] then return SEED_LOOKUP[key], "Seeds" end
	local cat = tostring(tool:GetAttribute("Category") or tool:GetAttribute("Type") or ""):lower()
	if cat:find("pet")  then return clean,"Pets"  end
	if cat:find("seed") then return clean,"Seeds" end
	return nil,nil
end

local function scanGrouped(category)
	local groups, order = {}, {}
	for _,src in ipairs({LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character}) do
		if src then
			for _,t in ipairs(src:GetChildren()) do
				if t:IsA("Tool") then
					local name,cat = resolveItemName(t)
					if name and cat==category and not (cat=="Pets" and name:lower():find("big",1,true)) then
						local rarity = (cat=="Pets" and PET_RARITY[name]) or (cat=="Seeds" and SEED_RARITY[name])
							or tostring(t:GetAttribute("Rarity") or "Common")
						local g = groups[name]
						if not g then g={name=name,rarity=rarity,count=0,tools={}}; groups[name]=g; table.insert(order,name) end
						g.count = g.count+1; table.insert(g.tools,t)
					end
				end
			end
		end
	end
	local rank={Super=7,Mythic=6,Legendary=5,Epic=4,Rare=3,Uncommon=2,Common=1}
	table.sort(order,function(a,b)
		local ra,rb=rank[groups[a].rarity] or 0, rank[groups[b].rarity] or 0
		if ra~=rb then return ra>rb end; return a<b
	end)
	local out={}; for _,n in ipairs(order) do table.insert(out,groups[n]) end; return out
end

