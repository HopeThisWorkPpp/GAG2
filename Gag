local function normalizeName(s)
	return (tostring(s or ""):lower():gsub("[%s_%-:'%.]", ""))
end

local PET_LOOKUP, SEED_LOOKUP = {}, {}
for k in pairs(PET_RARITY)  do PET_LOOKUP[normalizeName(k)]  = k end
for k in pairs(SEED_RARITY) do SEED_LOOKUP[normalizeName(k)] = k end

local INV_PREFIXES = {
	{ prefix = "Inv_Pets:",         category = "Pets"     },
	{ prefix = "Inv_Seeds:",        category = "Seeds"    },
	{ prefix = "Inv_Crates:",       category = "Crates"   },
	{ prefix = "Inv_Mushrooms:",    category = "Gear"     },
	{ prefix = "Inv_Sprinklers:",   category = "Gear"     },
	{ prefix = "Inv_WateringCans:", category = "Gear"     },
}

local function stripInvPrefix(name)
	local s = tostring(name or "")
	for _, p in ipairs(INV_PREFIXES) do
		s = s:gsub("^" .. p.prefix:gsub("([^%w])", "%%%1"), "")
	end
	return s
end

local function resolveItemName(tool)
	local clean = stripInvPrefix(tool.Name)
	local key   = normalizeName(clean)
	if PET_LOOKUP[key]  then return PET_LOOKUP[key],  "Pets"  end
	if SEED_LOOKUP[key] then return SEED_LOOKUP[key], "Seeds" end

	local ok, attrs = pcall(function() return tool:GetAttributes() end)
	if ok and type(attrs) == "table" then
		for _, v in pairs(attrs) do
			if type(v) == "string" and v ~= "" then
				local vk = normalizeName(stripInvPrefix(v))
				if PET_LOOKUP[vk]  then return PET_LOOKUP[vk],  "Pets"  end
				if SEED_LOOKUP[vk] then return SEED_LOOKUP[vk], "Seeds" end
			end
		end
	end

	for _, c in ipairs(tool:GetChildren()) do
		if c:IsA("StringValue") then
			local vk = normalizeName(stripInvPrefix(c.Value))
			if PET_LOOKUP[vk]  then return PET_LOOKUP[vk],  "Pets"  end
			if SEED_LOOKUP[vk] then return SEED_LOOKUP[vk], "Seeds" end
		end
		local cnk = normalizeName(stripInvPrefix(c.Name))
		if PET_LOOKUP[cnk]  then return PET_LOOKUP[cnk],  "Pets"  end
		if SEED_LOOKUP[cnk] then return SEED_LOOKUP[cnk], "Seeds" end
	end

	local cat = tostring(tool:GetAttribute("Category") or tool:GetAttribute("Type") or ""):lower()
	if cat:find("pet")  then return clean, "Pets"  end
	if cat:find("seed") then return clean, "Seeds" end

	return clean, "Other"
end

local function scanGrouped(category)
	local groups, order = {}, {}
	local sources = { LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character }
	for _, src in ipairs(sources) do
		if src then
			for _, t in ipairs(src:GetChildren()) do
				if t:IsA("Tool") then
					local name, cat = resolveItemName(t)
					local skip = (cat == "Pets" and name and name:lower():find("big", 1, true))
					if name and not skip and (category == "All" or cat == category) then
						local rarity =
							(cat == "Pets"  and PET_RARITY[name])
							or (cat == "Seeds" and SEED_RARITY[name])
							or tostring(t:GetAttribute("Rarity") or
								(cat == "Crates" and "Crate") or
								(cat == "Gear"   and "Gear")   or "Common")
						local g = groups[cat .. ":" .. name]
						if not g then
							g = { name = name, rarity = rarity, count = 0,
							      tools = {}, category = cat }
							groups[cat .. ":" .. name] = g
							table.insert(order, cat .. ":" .. name)
						end
						g.count = g.count + 1
						table.insert(g.tools, t)
					end
				end
			end
		end
	end
	local rank = { Super=7, Mythic=6, Legendary=5, Epic=4,
	               Rare=3, Uncommon=2, Common=1, Gear=0, Crate=0, Other=0 }
	local catRank = { Pets=3, Seeds=2, Crates=1, Gear=1, Other=0 }
	table.sort(order, function(a, b)
		local ga, gb = groups[a], groups[b]
		local cra, crb = catRank[ga.category] or 0, catRank[gb.category] or 0
		if cra ~= crb then return cra > crb end
		local ra, rb = rank[ga.rarity] or 0, rank[gb.rarity] or 0
		if ra ~= rb then return ra > rb end
		return ga.name < gb.name
	end)
	local out = {}
	for _, n in ipairs(order) do table.insert(out, groups[n]) end
	return out
end

local function getSellPrompt()
