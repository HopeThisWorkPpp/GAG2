		if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
	end
	local groups = scanGrouped(CurrentTab)
	if #groups == 0 then
		mk("TextLabel", { Size = UDim2.new(1, -12, 0, 60), BackgroundTransparency = 1,
			Text = "No " .. CurrentTab:lower() .. " found.\nMake sure they are in your Backpack.",
			Font = Enum.Font.Gotham, TextSize = 14, TextColor3 = Color3.fromRGB(180,180,180),
			TextWrapped = true, Parent = List })
		setStatus(("Scanned: 0 unique %s"):format(CurrentTab:lower()), false)
	else
		local total = 0
		for _, g in ipairs(groups) do total = total + g.count; buildRow(g) end
		setStatus(("%d unique %s (%d total)"):format(#groups, CurrentTab:lower(), total), true)
	end
	List.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 12)
end

