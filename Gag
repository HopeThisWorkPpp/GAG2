local function findMailboxPrompt()
	local gardens = Workspace:FindFirstChild("Gardens")
	if gardens then
		for _, plot in ipairs(gardens:GetChildren()) do
			local signs = plot:FindFirstChild("Signs")
			if signs then
				local mb = signs:FindFirstChild("GreyMailBox")
					 or signs:FindFirstChild("MailBox")
					 or signs:FindFirstChild("Mailbox")
				if mb then
					local part = mb:FindFirstChild("ProximityPromptPart") or mb.PrimaryPart
					if part then
						local prompt = part:FindFirstChild("MailboxPrompt")
							or part:FindFirstChildOfClass("ProximityPrompt")
						if prompt then return prompt end
					end
				end
			end
		end
	end
	for _, d in ipairs(Workspace:GetDescendants()) do
		if d:IsA("ProximityPrompt") then
			local txt = (tostring(d.ActionText) .. " " .. tostring(d.ObjectText)):lower()
			if txt:find("mail") then return d end
		end
	end
end

local function openMailbox()
	local old = PlayerGui:FindFirstChild("MailboxUI")
	if old then
		local closeBtn = old:FindFirstChild("CloseButton", true)
		if closeBtn then pcall(function() firesignal(closeBtn.MouseButton1Click) end) end
		task.wait(0.10)
	end
	local prompt = findMailboxPrompt()
	if not prompt then return nil, "MailboxPrompt not found" end
	pcall(function() fireproximityprompt(prompt) end)
	task.wait(0.35)

	local ui = PlayerGui:WaitForChild("MailboxUI", 5)
	if not ui then return nil, "MailboxUI did not appear" end
	local frame = ui:WaitForChild("Frame", 5)
	if not frame then return nil, "MailboxUI.Frame missing" end
	return ui
end

local function selectRecipient(ui, username)
	username = tostring(username or ""):gsub("^@", "")
	if username == "" then return false, "Empty recipient" end

	local frame         = ui:WaitForChild("Frame", 5)
	local sendingFrame  = frame and frame:WaitForChild("SendingFrame", 5)
	local selFrame      = sendingFrame and sendingFrame:WaitForChild("SelectPlayerFrame", 5)
	local topbar        = selFrame and selFrame:WaitForChild("Topbar", 5)
	local searchBox     = topbar  and topbar:WaitForChild("SearchBox", 5)
	if not searchBox then return false, "SearchBox missing" end

	pcall(function() searchBox:CaptureFocus() end)
	searchBox.Text = username
	task.wait(0.05)
	pcall(function() searchBox:ReleaseFocus() end)
	task.wait(0.05)
	pcall(function() VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Return, false, game) end)
	pcall(function() VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game) end)
	task.wait(0.30)

	local playerList = selFrame:WaitForChild("PlayerList", 5)
	if not playerList then return false, "PlayerList missing" end

	local deadline = tick() + 4
	while tick() < deadline do
		for _, row in ipairs(playerList:GetChildren()) do
			if row:IsA("Frame") and row.Name:match("^Search_") then
				local button = row:FindFirstChild("Button")
				local label  = button and button:FindFirstChild("PlayerUsername")
				if label then
					local clean = label.Text:lower():gsub("^@", "")
					if clean == username:lower() then
						clickGuiButton(button)
						return true
					end
				end
			end
		end
		task.wait(0.06)
	end
	return false, "Recipient '" .. username .. "' not found in list"
end

local function getInventoryFrame(ui)
	local frame        = ui:WaitForChild("Frame", 5)
	local sendingFrame = frame and frame:WaitForChild("SendingFrame", 5)
	local itemSend     = sendingFrame and sendingFrame:WaitForChild("ItemSendFrame", 5)
	local scrolls      = itemSend  and itemSend:WaitForChild("ScrollingFrames", 5)
	local inv          = scrolls   and scrolls:WaitForChild("InventoryFrame", 5)
	return inv, itemSend
end

local function buildInventoryIndex(inv)
	local idx = {}
	for _, child in ipairs(inv:GetChildren()) do
		local cname = child.Name
		for _, p in ipairs(INV_PREFIXES) do
			if cname:sub(1, #p.prefix) == p.prefix then
				idx[normalizeName(cname:sub(#p.prefix + 1))] = child
				break
			end
		end
	end
	return idx
end

local function clickInventoryItem(itemFrame)
	local inner  = itemFrame:FindFirstChildWhichIsA("Frame") or itemFrame
	local button = inner:FindFirstChildWhichIsA("GuiButton")
	if not button then
		for _, d in ipairs(itemFrame:GetDescendants()) do
			if d:IsA("GuiButton") then button = d; break end
		end
	end
	if button then clickGuiButton(button); return true end
	return false
end

local function mailItemsTo(recipient, planEntries)
	if recipient == "" then return false, "Recipient is empty" end
	if #planEntries == 0 then return false, "No items selected to mail" end

	local ui, err = openMailbox()
	if not ui then return false, err end

	local ok, perr = selectRecipient(ui, recipient)
	if not ok then return false, perr end
	task.wait(0.25)

	local inv, itemSend = getInventoryFrame(ui)
	if not inv then return false, "InventoryFrame missing" end

	local index = buildInventoryIndex(inv)
	local totalClicked, totalRequested = 0, 0

	for _, entry in ipairs(planEntries) do
		totalRequested = totalRequested + entry.count
		local frame = index[normalizeName(entry.name)]
		if frame then
			for i = 1, entry.count do
				if not frame.Parent then break end
				if not clickInventoryItem(frame) then break end
				totalClicked = totalClicked + 1
				if CFG.MailDelay > 0 then task.wait(CFG.MailDelay) else task.wait() end
			end
		end
	end

	task.wait(0.5)

	local sendButton = itemSend:WaitForChild("SendButton", 5)
	if sendButton and sendButton:IsA("GuiButton") then
		clickGuiButton(sendButton)
	else
		return false, "SendButton missing"
	end

	return true, string.format("Mailed %d / %d clicks to %s", totalClicked, totalRequested, recipient)
end

