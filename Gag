local function buildSellRow(group)
	local key=group.name; local color=RARITY_COLOR[group.rarity] or RARITY_COLOR.Other
	local r=mk("Frame",{Size=UDim2.new(1,-8,0,46),BackgroundColor3=TH.row,BorderSizePixel=0,Parent=List})
	mk("UICorner",{CornerRadius=UDim.new(0,6),Parent=r}); mk("UIStroke",{Color=color,Thickness=1,Transparency=0.6,Parent=r})
	mk("TextLabel",{Size=UDim2.new(0.45,0,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,
		Text=("%s x%d"):format(group.name,group.count),Font=Enum.Font.GothamBold,TextSize=13,
		TextColor3=TH.text,TextXAlignment=Enum.TextXAlignment.Left,Parent=r})
	mk("TextLabel",{Size=UDim2.new(0.2,0,0,16),Position=UDim2.new(0.45,0,0.5,-8),BackgroundTransparency=1,
		Text=group.rarity,Font=Enum.Font.GothamMedium,TextSize=11,TextColor3=color,Parent=r})
	local qty=SelectedQty[CurrentTab][key] or 0
	local box=mk("TextBox",{Size=UDim2.new(0,64,0,30),Position=UDim2.new(1,-150,0.5,-15),BackgroundColor3=TH.input,
		Text=tostring(qty),PlaceholderText="0",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=TH.text,
		ClearTextOnFocus=false,Parent=r,PlaceholderColor3=TH.subtext})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=box})
	local maxB=mk("TextButton",{Size=UDim2.new(0,36,0,30),Position=UDim2.new(1,-82,0.5,-15),BackgroundColor3=Color3.fromRGB(60,100,70),Text="MAX",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=TH.text,Parent=r})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=maxB})
	local sellB=mk("TextButton",{Size=UDim2.new(0,38,0,30),Position=UDim2.new(1,-42,0.5,-15),BackgroundColor3=TH.accentDim,Text="Sell",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=TH.text,Parent=r})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=sellB})
	local function clamp(n) n=tonumber(n) or 0; if n<0 then n=0 end; if n>group.count then n=group.count end; return math.floor(n) end
	box.FocusLost:Connect(function() local n=clamp(box.Text); box.Text=tostring(n); SelectedQty[CurrentTab][key]=n>0 and n or nil end)
	maxB.MouseButton1Click:Connect(function() box.Text=tostring(group.count); SelectedQty[CurrentTab][key]=group.count end)
	sellB.MouseButton1Click:Connect(function()
		local n=clamp(box.Text); if n<=0 then setStatus("Enter quantity first",false) return end
		setStatus(("Selling %d %s..."):format(n,group.name),true)
		task.spawn(function()
			local need=true; local _,hrp=getSellPrompt()
			local myHRP=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if hrp and myHRP and (hrp.Position-myHRP.Position).Magnitude<8 then need=false end
			if need then teleportToSteven(); task.wait(0.15) end
			local sold,fail=0,0
			for i=1,n do local t=group.tools[i]; if t and t.Parent then if sellOneTool(t) then sold=sold+1 else fail=fail+1 end; task.wait(0.1) end end
			if CFG.TeleportBack and need then returnHome() end
			SelectedQty[CurrentTab][key]=nil
			setStatus(("Sold %d / %d (%d failed)"):format(sold,n,fail),fail==0); refresh()
		end)
	end)
end

local function buildMailRow(entry)
	local bucketKey = "Mail"..MailSubTab
	local key = entry.name
	local color = (MailSubTab=="Pets" and (PET_RARITY[entry.name] and RARITY_COLOR[PET_RARITY[entry.name]]))
		or (MailSubTab=="Seeds" and (SEED_RARITY[entry.name] and RARITY_COLOR[SEED_RARITY[entry.name]]))
		or (MailSubTab=="Crates" and RARITY_COLOR.Crate)
		or RARITY_COLOR.Gear
	local r=mk("Frame",{Size=UDim2.new(1,-8,0,46),BackgroundColor3=TH.row,BorderSizePixel=0,Parent=List})
	mk("UICorner",{CornerRadius=UDim.new(0,6),Parent=r}); mk("UIStroke",{Color=color,Thickness=1,Transparency=0.6,Parent=r})
	local label = entry.name .. (entry.count and (" x"..entry.count) or "")
	mk("TextLabel",{Size=UDim2.new(0.6,0,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,
		Text=label,Font=Enum.Font.GothamBold,TextSize=13,TextColor3=TH.text,TextXAlignment=Enum.TextXAlignment.Left,Parent=r})
	local qty=SelectedQty[bucketKey][key] or 0
	local box=mk("TextBox",{Size=UDim2.new(0,64,0,30),Position=UDim2.new(1,-150,0.5,-15),BackgroundColor3=TH.input,
		Text=tostring(qty),PlaceholderText="0",Font=Enum.Font.GothamBold,TextSize=13,TextColor3=TH.text,
		ClearTextOnFocus=false,Parent=r,PlaceholderColor3=TH.subtext})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=box})
	local maxB=mk("TextButton",{Size=UDim2.new(0,36,0,30),Position=UDim2.new(1,-82,0.5,-15),BackgroundColor3=Color3.fromRGB(60,100,70),Text="MAX",Font=Enum.Font.GothamBold,TextSize=10,TextColor3=TH.text,Parent=r})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=maxB})
	local mailB=mk("TextButton",{Size=UDim2.new(0,40,0,30),Position=UDim2.new(1,-42,0.5,-15),BackgroundColor3=TH.mailDim,Text="Mail",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=TH.text,Parent=r})
	mk("UICorner",{CornerRadius=UDim.new(0,5),Parent=mailB})
	local function clamp(n) n=tonumber(n) or 0; if n<0 then n=0 end; return math.floor(n) end
	box.FocusLost:Connect(function() local n=clamp(box.Text); box.Text=tostring(n); SelectedQty[bucketKey][key]=n>0 and n or nil end)
	maxB.MouseButton1Click:Connect(function() local v=entry.count or 999; box.Text=tostring(v); SelectedQty[bucketKey][key]=v end)
	mailB.MouseButton1Click:Connect(function()
		local n=clamp(box.Text); if n<=0 then setMailMsg("Enter quantity first",false) return end
		setMailMsg(("Mailing %d × %s..."):format(n,entry.name),true)
		task.spawn(function()
			local ok,msg=sendMailPlan({{entry=entry,count=n}})
			setMailMsg(tostring(msg),ok); SelectedQty[bucketKey][key]=nil
			task.wait(0.6); refresh()
		end)
	end)
end

refresh = function()
	for _,c in ipairs(List:GetChildren()) do if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end end
	if CurrentTab=="Mail" then
		if not Mail.recipientLocked then
			mk("TextLabel",{Size=UDim2.new(1,-12,0,60),BackgroundTransparency=1,
				Text="Connect to a recipient first.\nType a username above and press Connect.",
				Font=Enum.Font.Gotham,TextSize=13,TextColor3=TH.subtext,TextWrapped=true,Parent=List})
		else
			local data = readInventory()
			local bucket = data[MailSubTab] or {}
			if #bucket==0 then
				mk("TextLabel",{Size=UDim2.new(1,-12,0,60),BackgroundTransparency=1,
					Text="No "..MailSubTab:lower().." in your backpack right now.",
					Font=Enum.Font.Gotham,TextSize=13,TextColor3=TH.subtext,TextWrapped=true,Parent=List})
			else
				for _,e in ipairs(bucket) do buildMailRow(e) end
			end
			setStatus(("Mail • %s: %d items  →  %s"):format(MailSubTab,#bucket,Mail.recipient),true)
		end
	else
		local groups=scanGrouped(CurrentTab)
		if #groups==0 then
			mk("TextLabel",{Size=UDim2.new(1,-12,0,60),BackgroundTransparency=1,
				Text="No "..CurrentTab:lower().." in backpack.",Font=Enum.Font.Gotham,TextSize=13,
				TextColor3=TH.subtext,TextWrapped=true,Parent=List})
			setStatus("0 items",false)
		else
			local total=0; for _,g in ipairs(groups) do total=total+g.count; buildSellRow(g) end
			setStatus(("%d unique • %d total"):format(#groups,total),true)
		end
	end
	List.CanvasSize=UDim2.new(0,0,0,ListLayout.AbsoluteContentSize.Y+12)
end

local function paintSubTabs()
	for btn,name in pairs({[SeedsBtn]="Seeds",[PetsBtn]="Pets",[CratesBtn]="Crates",[GearsBtn]="Gears"}) do
		if name==MailSubTab then btn.BackgroundColor3=TH.mailDim; btn.TextColor3=TH.text
		else btn.BackgroundColor3=TH.row; btn.TextColor3=TH.subtext end
	end
end

local function setTab(t)
	CurrentTab=t
	local mail = (t=="Mail")
	for btn,name in pairs({[PetsTab]="Pets",[SeedsTab]="Seeds",[MailTab]="Mail"}) do
		if name==t then btn.BackgroundColor3 = (name=="Mail") and TH.mailDim or TH.accentDim; btn.TextColor3=TH.text
		else btn.BackgroundColor3=TH.panel; btn.TextColor3=TH.subtext end
	end
	MailHeader.Visible=mail; MailSendAll.Visible=mail; SellSel.Visible=not mail; SellAll.Visible=not mail
	List.Size = mail and UDim2.new(1,0,1,-310) or UDim2.new(1,0,1,-200)
	paintSubTabs(); refresh()
end

