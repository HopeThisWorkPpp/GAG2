local function buildRow(group, index)
	local key    = group.name
	local rarity = group.rarity or "Common"
	local color  = RARITY_COLOR[rarity] or RARITY_COLOR.Other

	local r = mk("Frame", { Size = UDim2.new(1, -8, 0, 48),
		BackgroundColor3 = (index % 2 == 0) and TH.bgRow or TH.bgRowAlt,
		BorderSizePixel = 0, Parent = List })
	mk("UICorner", { CornerRadius = UDim.new(0, 7), Parent = r })

	local bar = mk("Frame", { Size = UDim2.new(0, 4, 1, -8), Position = UDim2.new(0, 4, 0, 4),
		BackgroundColor3 = color, BorderSizePixel = 0, Parent = r })
	mk("UICorner", { CornerRadius = UDim.new(0, 2), Parent = bar })

	mk("TextLabel", {
		Size = UDim2.new(0.45, -20, 0, 20), Position = UDim2.new(0, 16, 0, 6),
		BackgroundTransparency = 1, Text = group.name,
		Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = TH.text,
		TextXAlignment = Enum.TextXAlignment.Left, Parent = r,
		TextTruncate = Enum.TextTruncate.AtEnd,
	})
	mk("TextLabel", {
		Size = UDim2.new(0.45, -20, 0, 16), Position = UDim2.new(0, 16, 0, 26),
		BackgroundTransparency = 1,
		Text = (CurrentTab == "Mail" and (group.category .. " • ") or "") .. rarity .. "  •  x" .. group.count,
		Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = color,
		TextXAlignment = Enum.TextXAlignment.Left, Parent = r,
	})

	local qty = SelectedQty[CurrentTab][key] or 0
	local box = mk("TextBox", {
		Size = UDim2.new(0, 68, 0, 30), Position = UDim2.new(1, -158, 0.5, -15),
		BackgroundColor3 = TH.inputBg, Text = tostring(qty), PlaceholderText = "0",
		Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = TH.text,
		ClearTextOnFocus = false, Parent = r, PlaceholderColor3 = TH.subtext,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = box })
	mk("UIStroke", { Color = color, Thickness = 1, Transparency = 0.5, Parent = box })

	local maxBtn = mk("TextButton", {
		Size = UDim2.new(0, 40, 0, 30), Position = UDim2.new(1, -86, 0.5, -15),
		BackgroundColor3 = Color3.fromRGB(60,100,70), Text = "MAX",
		Font = Enum.Font.GothamBold, TextSize = 10, TextColor3 = TH.text, Parent = r,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = maxBtn })

	local actionLabel = (CurrentTab == "Mail") and "Mail" or "Sell"
	local actionColor = (CurrentTab == "Mail") and TH.mailDim or TH.accentDim
	local rowAct = mk("TextButton", {
		Size = UDim2.new(0, 42, 0, 30), Position = UDim2.new(1, -42, 0.5, -15),
		BackgroundColor3 = actionColor, Text = actionLabel,
		Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = TH.text, Parent = r,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = rowAct })

	local function clampQty(n)
		n = tonumber(n) or 0
		if n < 0 then n = 0 end
		if CurrentTab ~= "Mail" and n > group.count then n = group.count end
		return math.floor(n)
	end

	box.FocusLost:Connect(function()
		local n = clampQty(box.Text); box.Text = tostring(n)
		SelectedQty[CurrentTab][key] = n > 0 and n or nil
	end)
	maxBtn.MouseButton1Click:Connect(function()
		box.Text = tostring(group.count)
		SelectedQty[CurrentTab][key] = group.count
	end)

	rowAct.MouseButton1Click:Connect(function()
		local n = clampQty(box.Text)
		if n <= 0 then setStatus("Enter quantity first", false) return end
		SelectedQty[CurrentTab][key] = n

		if CurrentTab == "Mail" then
			local recip = RecipientBox.Text:gsub("^%s+", ""):gsub("%s+$", "")
			if recip == "" then setStatus("Type recipient username first", false) return end
			setStatus(("Mailing %d × %s → %s..."):format(n, group.name, recip), true)
			task.spawn(function()
				local ok, msg = mailItemsTo(recip, {{ name = group.name, count = n }})
				setStatus(tostring(msg or (ok and "Mail sent" or "Mail failed")), ok)
				SelectedQty.Mail[key] = nil
				task.wait(0.4); refresh()
			end)
		else
			setStatus(("Selling %d %s..."):format(n, group.name), true)
			task.spawn(function()
				local needTP = true
				local _, hrp = getSellPrompt()
				local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
				if hrp and myHRP and (hrp.Position - myHRP.Position).Magnitude < 8 then needTP = false end
				if needTP then teleportTo(hrp); task.wait(0.15) end
				local sold, fail = 0, 0
				for i = 1, n do
					local tool = group.tools[i]
					if tool and tool.Parent then
						if sellOneTool(tool) then sold = sold + 1 else fail = fail + 1 end
						task.wait(0.1)
					end
				end
				if CFG.TeleportBack and needTP then returnHome() end
				SelectedQty[CurrentTab][key] = nil
				setStatus(("Sold %d / %d (%d failed)"):format(sold, n, fail), fail == 0)
				refresh()
			end)
		end
	end)
end

refresh = function()
	for _, c in ipairs(List:GetChildren()) do
		if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
	end
	local scanCat = (CurrentTab == "Mail") and "All" or CurrentTab
	local groups  = scanGrouped(scanCat)
	if #groups == 0 then
		mk("TextLabel", { Size = UDim2.new(1, -12, 0, 60), BackgroundTransparency = 1,
			Text = "No items found.\nMake sure they are in your Backpack.",
			Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = TH.subtext,
			TextWrapped = true, Parent = List })
		setStatus("Scanned: 0 items", false)
	else
		local total = 0
		for i, g in ipairs(groups) do total = total + g.count; buildRow(g, i) end
		setStatus(("%d unique • %d total"):format(#groups, total), true)
	end
	List.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 12)
end

local function setTab(t)
	CurrentTab = t
	local active = TH.accentDim
	if t == "Mail" then active = TH.mailDim end

	for tab, name in pairs({ [PetsTab]="Pets", [SeedsTab]="Seeds", [MailTab]="Mail" }) do
		if name == t then
			tab.BackgroundColor3 = active
			tab.TextColor3 = TH.text
		else
			tab.BackgroundColor3 = TH.bgPanel
			tab.TextColor3 = TH.subtext
		end
	end

	local mailMode = (t == "Mail")
	MailHeader.Visible = mailMode
	MailSel.Visible    = mailMode
	SellSel.Visible    = not mailMode
	SellAll.Visible    = not mailMode
	List.Size          = mailMode and UDim2.new(1, 0, 1, -310) or UDim2.new(1, 0, 1, -240)
	refresh()
end

