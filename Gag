local function performSell(verbose)
    local total, sold, failed = 0, 0, 0
    local list = scanInventory(CurrentTab)
    for _, it in ipairs(list) do
        local key = it.name .. "|" .. it.rarity
        local pass = Selected[CurrentTab][key] == true
        if pass and (RarityFilter == "Any" or it.rarity == RarityFilter) then
            total = total + 1
            local ok = fireSell(it.name, it.uuid, CurrentTab)
            if ok then sold = sold + 1 else failed = failed + 1 end
            task.wait(0.1)
        end
    end
    if verbose then
        if total == 0 then setStatus("Nothing selected. Tick items first.", "warn")
        else setStatus(("Sold %d/%d (%d failed)"):format(sold, total, failed),
            failed == 0 and "ok" or "warn") end
    end
    return sold
end

