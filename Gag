local INV_PREFIX = { Seeds="Inv_Seeds:", Pets="Inv_Pets:", Crates="Inv_Crates:" }
local GEAR_PREFIXES = { "Inv_Mushrooms:", "Inv_Sprinklers:", "Inv_WateringCans:" }

local Mail = { ui=nil, sendingFrame=nil, itemSendFrame=nil, inventoryFrame=nil, recipientLocked=false, recipient="" }
