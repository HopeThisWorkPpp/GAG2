local function normalizeName(s)
	return (tostring(s or ""):lower():gsub("[%s_%-:'%.]", ""))
end

local PET_LOOKUP, SEED_LOOKUP = {}, {}
for k in pairs(PET_RARITY) do PET_LOOKUP[normalizeName(k)] = k end
for k in pairs(SEED_RARITY) do SEED_LOOKUP[normalizeName(k)] = k end

local function stripInvPrefix(name)
	local s = tostring(name or "")
	for _, p in ipairs({"^Inv_Pets:", "^Inv_Seeds:", "^Inv_Crates:",
		"^Inv_Mushrooms:", "^Inv_Sprinklers:", "^Inv_WateringCans:"}) do
		s = s:gsub(p, "")
	end
	return s
end

local function resolveItemName(tool)
	local clean = stripInvPrefix(tool.Name)
	local key = normalizeName(clean)
	if PET_LOOKUP[key] then return PET_LOOKUP[key], "Pets" end
	if SEED_LOOKUP[key] then return SEED_LOOKUP[key], "Seeds" end

	local ok, attrs = pcall(function() return tool:GetAttributes() end)
	if ok and type(attrs) == "table" then
		for _, v in pairs(attrs) do
			if type(v) == "string" and v ~= "" then
				local vk = normalizeName(stripInvPrefix(v))
				if PET_LOOKUP[vk] then return PET_LOOKUP[vk], "Pets" end
				if SEED_LOOKUP[vk] then return SEED_LOOKUP[vk], "Seeds" end
			end
		end
	end

	for _, c in ipairs(tool:GetChildren()) do
		if c:IsA("StringValue") then
			local vk = normalizeName(stripInvPrefix(c.Value))
			if PET_LOOKUP[vk] then return PET_LOOKUP[vk], "Pets" end
			if SEED_LOOKUP[vk] then return SEED_LOOKUP[vk], "Seeds" end
		end
		local cnk = normalizeName(stripInvPrefix(c.Name))
		if PET_LOOKUP[cnk] then return PET_LOOKUP[cnk], "Pets" end
		if SEED_LOOKUP[cnk] then return SEED_LOOKUP[cnk], "Seeds" end
	end

	local cat = tostring(tool:GetAttribute("Category") or tool:GetAttribute("Type") or ""):lower()
	if cat:find("pet") then return clean, "Pets" end
	if cat:find("seed") then return clean, "Seeds" end

	return nil, nil
end

local function scanGrouped(category)
	local groups, order = {}, {}
	local sources = { LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character }
	for _, src in ipairs(sources) do
		if src then
			for _, t in ipairs(src:GetChildren()) do
				if t:IsA("Tool") then
					local name, cat = resolveItemName(t)
					if name and cat == category then
						local rarity = (category == "Pets" and PET_RARITY[name])
							or (category == "Seeds" and SEED_RARITY[name])
							or tostring(t:GetAttribute("Rarity") or "Common")
						local g = groups[name]
						if not g then
							g = { name = name, rarity = rarity, count = 0, tools = {} }
							groups[name] = g; table.insert(order, name)
						end
						g.count = g.count + 1
						table.insert(g.tools, t)
					end
				end
			end
		end
	end
	local rank = { Super=7, Mythic=6, Legendary=5, Epic=4,
		Rare=3, Uncommon=2, Common=1 }
	table.sort(order, function(a, b)
		local ra, rb = rank[groups[a].rarity] or 0, rank[groups[b].rarity] or 0
		if ra ~= rb then return ra > rb end
		return a < b
	end)
	local out = {}
	for _, n in ipairs(order) do table.insert(out, groups[n]) end
	return out
end

local function getStevenModel()
	local npcs = Workspace:FindFirstChild("NPCS") or Workspace:FindFirstChild("NPCs")
	if not npcs then return nil end
	return npcs:FindFirstChild(CFG.NPCName)
end

local function getSellPrompt()
	local steven = getStevenModel()
	if not steven then return nil end
	local hrp = steven:FindFirstChild("HumanoidRootPart") or steven.PrimaryPart
	if not hrp then return nil end
	return hrp:FindFirstChildOfClass("ProximityPrompt"), hrp
end

local function findDialogInModel(model)
	if not model then return nil end
	for _, d in ipairs(model:GetDescendants()) do
		if d:IsA("Dialog") then return d end
	end
	return nil
end

-- Fire Roblox Dialog's DialogChoiceSelected signal directly (preferred path)
local function selectDialogChoiceByText(needle)
	local steven = getStevenModel()
	local dialog = findDialogInModel(steven)
	if not dialog then return false end
	needle = tostring(needle):lower()
	local target
	for _, c in ipairs(dialog:GetChildren()) do
		if c:IsA("DialogChoice") then
			local ud = tostring(c.UserDialog or ""):lower()
			if ud:find(needle, 1, true) then target = c; break end
		end
	end
	if not target then return false end
	local fired = false
	pcall(function()
		if firesignal then
			firesignal(dialog.DialogChoiceSelected, LocalPlayer, target)
			fired = true
		end
	end)
	if not fired then
		pcall(function()
			dialog.DialogChoiceSelected:Fire(LocalPlayer, target)
			fired = true
		end)
	end
	return fired
end

local function clickBtn(btn)
	if not btn then return end
	pcall(function() if firesignal then firesignal(btn.MouseButton1Click) end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Down) end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Up) end end)
	pcall(function() if firesignal then firesignal(btn.Activated) end end)
	pcall(function() btn.MouseButton1Click:Fire() end)
	pcall(function() btn.Activated:Fire(Enum.UserInputType.MouseButton1) end)
end

local function isAncestorVisible(g)
	local p = g
	while p and p ~= PlayerGui do
		if p:IsA("GuiObject") and p.Visible == false then return false end
		p = p.Parent
	end
	return true
end

-- Hotbar / backpack / generic blocklist to avoid clicking wrong elements
local FORBIDDEN_PATHS = {
	"backpack", "hotbar", "inventory", "topbar", "chat", "coregui.robloxgui",
	"healthgui", "playerlist", "emote", "leaderboard", "shop", "settings",
}

local function pathLooksForbidden(full)
	for _, kw in ipairs(FORBIDDEN_PATHS) do
		if full:find(kw, 1, true) then return true end
	end
	return false
end

-- Find a dialog choice button by exact-ish text match, with strict guards
local function findDialogButtonStrict(must, mustNot)
	mustNot = mustNot or {}
	for _, g in ipairs(PlayerGui:GetDescendants()) do
		if (g:IsA("TextButton") or g:IsA("ImageButton")) and g.Visible and isAncestorVisible(g) then
			local full = g:GetFullName():lower()
			if not full:find("template") and not pathLooksForbidden(full) then
				-- Only consider buttons whose own visible text matches (don't crawl descendants;
				-- that's what made it match hotbar containers before)
				local txt = ""
				if g:IsA("TextButton") then txt = (g.Text or "") end
				-- Check direct TextLabel siblings/children (1 level deep only)
				if txt == "" then
					for _, d in ipairs(g:GetChildren()) do
						if d:IsA("TextLabel") and d.Visible then
							txt = (d.Text or "")
							if txt ~= "" then break end
						end
					end
				end
				txt = txt:lower()
				if txt ~= "" then
					local ok = true
					for _, kw in ipairs(must) do
						if not txt:find(kw, 1, true) then ok = false; break end
					end
					if ok then
						for _, kw in ipairs(mustNot) do
							if txt:find(kw, 1, true) then ok = false; break end
						end
					end
					if ok then return g end
				end
			end
		end
	end
	return nil
end

local function waitForStrict(must, mustNot, timeout)
	timeout = timeout or 2
	local t0 = tick()
	while tick() - t0 < timeout do
		local b = findDialogButtonStrict(must, mustNot)
		if b then return b end
		task.wait(0.08)
	end
	return nil
end

local origCFrame
local function teleportToSteven()
	local _, hrp = getSellPrompt()
	if not hrp then return false end
	local char = LocalPlayer.Character
	local myHRP = char and char:FindFirstChild("HumanoidRootPart")
	if not myHRP then return false end
	origCFrame = myHRP.CFrame
	myHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, 4)
	return true
end
local function returnHome()
	if not origCFrame then return end
	local char = LocalPlayer.Character
	local myHRP = char and char:FindFirstChild("HumanoidRootPart")
	if myHRP then myHRP.CFrame = origCFrame end
	origCFrame = nil
end
local function talkToSteven()
	local prompt = getSellPrompt()
	if not prompt then return false end
	return (pcall(function() fireproximityprompt(prompt) end))
end
local function equipTool(tool)
	local char = LocalPlayer.Character
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	if hum then pcall(function() hum:EquipTool(tool) end) end
end

-- Always pick option "Sell This!" — Dialog API first, strict GUI button second. NO keypress.
local function pickSellThis()
	if selectDialogChoiceByText("sell this") then return true end
	local btn = waitForStrict(
		{ "sell this" },
		{ "sell inventory", "sell all", "how much", "bargain", "nevermind" },
		2
	)
	if btn then
		for _ = 1, 3 do
			if not btn or not btn.Parent then break end
			clickBtn(btn); task.wait(0.12)
		end
		return true
	end
	return false
end

local function sellOneTool(tool)
	if not tool or not tool.Parent then return false end
	equipTool(tool); task.wait(0.35)
	talkToSteven(); task.wait(0.2)
	local ok = pickSellThis()
	task.wait(0.3)
	return ok
end

local function sellInventoryViaNPC()
	talkToSteven(); task.wait(0.2)
	if selectDialogChoiceByText("sell inventory") then
		task.wait(0.3); return true
	end
	local btn = waitForStrict({ "sell inventory" }, { "sell this" }, 2)
	if not btn then return false end
	for _ = 1, 2 do clickBtn(btn); task.wait(0.15) end
	task.wait(0.3)
	return true
end

