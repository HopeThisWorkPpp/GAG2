-- ========================== REMOTE DISCOVERY ==========================
local SellRemoteCandidates = {
    "SellPet", "Sell_Pet", "SellPetEvent",
    "SellItem", "Sell", "SellRemote",
    "SellSeed", "SellInventory", "Sell_Item",
}

local function findRemote()
    for _, name in ipairs(SellRemoteCandidates) do
        local found = ReplicatedStorage:FindFirstChild(name, true)
        if found and (found:IsA("RemoteEvent") or found:IsA("RemoteFunction")) then
            return found
        end
    end
    for _, d in ipairs(ReplicatedStorage:GetDescendants()) do
        if (d:IsA("RemoteEvent") or d:IsA("RemoteFunction"))
            and d.Name:lower():find("sell") then
            return d
        end
    end
    return nil
end

local SellRemote = findRemote()

local function fireSell(itemName, uuid, category)
    if not SellRemote then return false, "No sell remote found" end
    local ok, err = pcall(function()
        local args = { itemName, uuid, category }
        if SellRemote:IsA("RemoteEvent") then
            SellRemote:FireServer(unpack(args))
        else
            SellRemote:InvokeServer(unpack(args))
        end
    end)
    return ok, err
end

-- ========================== INVENTORY SCAN ==========================
local function getInventoryFolder(category)
    local data = LocalPlayer:FindFirstChild("Data") or LocalPlayer:FindFirstChild("PlayerData")
    if data then
        local cat = data:FindFirstChild(category)
        if cat then return cat end
    end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    return backpack
end

local function getItemRarity(item)
    local r = item:GetAttribute("Rarity") or item:GetAttribute("Tier")
    if r then return tostring(r) end
    local v = item:FindFirstChild("Rarity")
    if v and v:IsA("StringValue") then return v.Value end
    return "Unknown"
end

local function getItemUUID(item)
    return item:GetAttribute("UUID")
        or item:GetAttribute("Id")
        or item:GetAttribute("UID")
        or item.Name
end

local function scanInventory(category)
    local list = {}
    local folder = getInventoryFolder(category)
    if not folder then return list end

    for _, item in ipairs(folder:GetChildren()) do
        local isCategory = true
        if folder.Name == "Backpack" then
            local cat = item:GetAttribute("Category") or item:GetAttribute("Type")
            isCategory = cat and tostring(cat):lower():find(category:lower():sub(1,3))
        end
        if isCategory then
            table.insert(list, {
                name     = item:GetAttribute("ItemName") or item.Name,
                rarity   = getItemRarity(item),
                uuid     = getItemUUID(item),
                instance = item,
            })
        end
    end
    return list
end

