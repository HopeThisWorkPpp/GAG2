local GuiService = game:GetService("GuiService")
local function clickBtn(btn)
	if not btn or not btn.Parent then return false end
	-- 1) Signal-based clicks first (bypass any overlay GUI on top of the target)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Down) end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Up) end end)
	pcall(function() if firesignal then firesignal(btn.MouseButton1Click) end end)
	pcall(function() if firesignal then firesignal(btn.Activated) end end)
	-- 2) Virtual mouse/touch fallback WITH GuiInset compensation
	local p,sz=btn.AbsolutePosition,btn.AbsoluteSize
	local insetY=0
	pcall(function() insetY = GuiService:GetGuiInset().Y end)
	local sg = btn:FindFirstAncestorOfClass("ScreenGui")
	if sg and sg.IgnoreGuiInset then insetY = 0 end
	local cx,cy=math.floor(p.X+sz.X*0.5),math.floor(p.Y+sz.Y*0.5+insetY)
	pcall(function() VirtualInputManager:SendMouseButtonEvent(cx,cy,0,true,game,0); task.wait(0.02); VirtualInputManager:SendMouseButtonEvent(cx,cy,0,false,game,0) end)
	pcall(function() VirtualInputManager:SendTouchEvent(1,1,cx,cy); task.wait(0.02); VirtualInputManager:SendTouchEvent(1,2,cx,cy); VirtualInputManager:SendTouchEvent(1,3,cx,cy) end)
	return true
end

local function findBillboardOpt(needle)
	needle=needle:lower()
	local roots={PlayerGui}; pcall(function() table.insert(roots,CoreGui) end)
	for _,r in ipairs(roots) do for _,d in ipairs(r:GetDescendants()) do
		if d.Name=="Option_UI" and d:IsA("GuiObject") then
			local te,btn
			for _,c in ipairs(d:GetDescendants()) do
				if not te and c.Name=="Text_Element" and c:IsA("TextLabel") then te=c end
				if not btn and (c:IsA("ImageButton") or c:IsA("TextButton")) then btn=c end
			end
			if te and btn and tostring(te.Text or ""):lower():find(needle,1,true) then return btn end
		end
	end end
end
local function waitOpt(needle,t) local t0=tick(); while tick()-t0<(t or 4) do local b=findBillboardOpt(needle); if b then return b end; task.wait(0.08) end end
local function sellOneTool(tool)
	if not tool or not tool.Parent then return false end
	equipTool(tool); task.wait(0.15); talkToSteven(); task.wait(0.3)
	local b=waitOpt("sell this",4); if not b then return false end
	clickBtn(b); task.wait(0.15); return true
end
local function sellInvViaNPC()
	talkToSteven(); task.wait(0.15)
	local b=waitOpt("sell inventory",4); if not b then return false end
	for _=1,2 do clickBtn(b); task.wait(0.02) end; task.wait(0.1); return true
end

