    mk("TextLabel",{ Size=UDim2.new(1,-120,1,0), Position=UDim2.new(0,34,0,0), BackgroundTransparency=1,
        Text=item.name, Font=Enum.Font.Gotham, TextSize=13, TextColor3=Color3.fromRGB(230,230,230),
        TextXAlignment=Enum.TextXAlignment.Left, Parent=r })
    mk("TextLabel",{ Size=UDim2.new(0,80,1,0), Position=UDim2.new(1,-86,0,0), BackgroundTransparency=1,
        Text=tostring(item.rarity), Font=Enum.Font.GothamMedium, TextSize=12,
        TextColor3=Color3.fromRGB(180,220,190), TextXAlignment=Enum.TextXAlignment.Right, Parent=r })
    c.MouseButton1Click:Connect(function()
        Selected[CurrentTab][key]= not Selected[CurrentTab][key] or nil
        local on=Selected[CurrentTab][key]==true
        c.BackgroundColor3 = on and Color3.fromRGB(60,180,90) or Color3.fromRGB(60,60,60)
        c.Text = on and "X" or ""
    end)
end

refresh = function()
    for _,c in ipairs(List:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
    end
    local items=scanTools(CurrentTab)
    local seen={}
    local shown=0
    for _,it in ipairs(items) do
        local k=it.name.."|"..it.rarity
        if not seen[k] then seen[k]=true; row(it); shown=shown+1 end
    end
    List.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+12)
    if shown==0 then
        mk("TextLabel",{ Size=UDim2.new(1,-12,0,60), BackgroundTransparency=1,
            Text="No "..CurrentTab:lower().." found in Backpack/Character or PlayerGui inventory. Equip them or use 'Sell ALL' to sell entire inventory via Steven.",
            Font=Enum.Font.Gotham, TextSize=13, TextColor3=Color3.fromRGB(180,180,180),
            TextWrapped=true, Parent=List })
        setStatus(("Scanned: 0 %s found"):format(CurrentTab:lower()), false)
    else
        setStatus(("Found %d %s (tap row to select)"):format(shown, CurrentTab:lower()), true)
    end
end

