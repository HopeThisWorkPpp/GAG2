ConnectBtn.MouseButton1Click:Connect(function()
	local u=RecipientBox.Text:gsub("^%s+",""):gsub("%s+$","")
	if u=="" then setMailMsg("Type a username first",false) return end
	setMailMsg("Opening mailbox...",true)
	task.spawn(function()
		Mail.ui=nil; Mail.recipientLocked=false
		local ui,err=openMailbox(); if not ui then setMailMsg(err,false) return end
		setMailMsg("Searching for "..u.."...",true)
		local ok,msg=pickRecipient(u)
		setMailMsg(msg,ok)
		if ok then refresh() end
	end)
end)

MailSendAll.MouseButton1Click:Connect(function()
	if not Mail.recipientLocked then setMailMsg("Connect to a recipient first",false) return end
	local data=readInventory(); local plan={}
	for _,sub in ipairs({"Seeds","Pets","Crates","Gears"}) do
		local bk="Mail"..sub
		for _,e in ipairs(data[sub] or {}) do
			local n=SelectedQty[bk][e.name]
			if n and n>0 then table.insert(plan,{entry=e,count=n}) end
		end
	end
	if #plan==0 then setMailMsg("Pick at least one item with qty > 0",false) return end
	setMailMsg(("Mailing %d item types..."):format(#plan),true)
	task.spawn(function()
		local ok,msg=sendMailPlan(plan); setMailMsg(tostring(msg),ok)
		for _,sub in ipairs({"Seeds","Pets","Crates","Gears"}) do SelectedQty["Mail"..sub]={} end
		task.wait(0.6); refresh()
	end)
end)

