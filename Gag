	local box = mk("TextBox", {
		Size = UDim2.new(0, 64, 0, 30), Position = UDim2.new(1, -150, 0.5, -15),
		BackgroundColor3 = Color3.fromRGB(50,60,52),
		Text = tostring(qty), PlaceholderText = "0",
		Font = Enum.Font.GothamBold, TextSize = 14,
		TextColor3 = Color3.fromRGB(255,255,255),
		ClearTextOnFocus = false, Parent = r,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = box })
	mk("UIStroke", { Color = Color3.fromRGB(80,180,110), Thickness = 1, Transparency = 0.5, Parent = box })

	local maxBtn = mk("TextButton", {
		Size = UDim2.new(0, 36, 0, 30), Position = UDim2.new(1, -82, 0.5, -15),
		BackgroundColor3 = Color3.fromRGB(60,100,70),
		Text = "MAX", Font = Enum.Font.GothamBold, TextSize = 11,
		TextColor3 = Color3.fromRGB(255,255,255), Parent = r,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = maxBtn })

	local rowSell = mk("TextButton", {
		Size = UDim2.new(0, 38, 0, 30), Position = UDim2.new(1, -42, 0.5, -15),
		BackgroundColor3 = Color3.fromRGB(60,140,80),
		Text = "Sell", Font = Enum.Font.GothamBold, TextSize = 12,
		TextColor3 = Color3.fromRGB(255,255,255), Parent = r,
	})
	mk("UICorner", { CornerRadius = UDim.new(0, 5), Parent = rowSell })

	local function clampQty(n)
		n = tonumber(n) or 0
		if n < 0 then n = 0 end
		if n > group.count then n = group.count end
		return math.floor(n)
	end

	box.FocusLost:Connect(function()
		local n = clampQty(box.Text); box.Text = tostring(n)
		SelectedQty[CurrentTab][key] = n > 0 and n or nil
	end)
	maxBtn.MouseButton1Click:Connect(function()
		box.Text = tostring(group.count)
		SelectedQty[CurrentTab][key] = group.count
	end)
	rowSell.MouseButton1Click:Connect(function()
		local n = clampQty(box.Text)
		if n <= 0 then setStatus("Enter quantity first", false) return end
		SelectedQty[CurrentTab][key] = n
		setStatus(("Selling %d %s..."):format(n, group.name), true)
		task.spawn(function()
			local needTP = true
			local _, hrp = getSellPrompt()
			local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			if hrp and myHRP and (hrp.Position - myHRP.Position).Magnitude < 8 then needTP = false end
			if needTP then teleportToSteven(); task.wait(0.5) end
			local sold, fail = 0, 0
			for i = 1, n do
				local tool = group.tools[i]
				if tool and tool.Parent then
					if sellOneTool(tool) then sold = sold + 1 else fail = fail + 1 end
					task.wait(0.4)
				end
			end
			if CFG.TeleportBack and needTP then returnHome() end
			SelectedQty[CurrentTab][key] = nil
			setStatus(("Sold %d / %d (%d failed)"):format(sold, n, fail), fail == 0)
			refresh()
		end)
	end)
end

