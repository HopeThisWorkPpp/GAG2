	mk("TextLabel", { Size = UDim2.new(0.45, 0, 1, 0), Position = UDim2.new(0, 10, 0, 0),
		BackgroundTransparency = 1, Text = ("%s x%d"):format(group.name, group.count),
		Font = Enum.Font.GothamBold, TextSize = 14,
		TextColor3 = Color3.fromRGB(235,235,235),
		TextXAlignment = Enum.TextXAlignment.Left, Parent = r })

	mk("TextLabel", { Size = UDim2.new(0.2, 0, 0, 18), Position = UDim2.new(0.45, 0, 0.5, -9),
		BackgroundTransparency = 1, Text = rarity, Font = Enum.Font.GothamMedium,
		TextSize = 12, TextColor3 = color,
