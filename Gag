local function findRemote()
    if CustomRemote then return CustomRemote end
    for _, name in ipairs(SellRemoteCandidates) do
        local found = ReplicatedStorage:FindFirstChild(name, true)
        if found and (found:IsA("RemoteEvent") or found:IsA("RemoteFunction")) then return found end
    end
    for _, d in ipairs(ReplicatedStorage:GetDescendants()) do
        if (d:IsA("RemoteEvent") or d:IsA("RemoteFunction")) and d.Name:lower():find("sell") then return d end
    end
    return nil
end
SellRemote = findRemote()

local function resolvePath(path)
    if not path or path == "" then return nil end
    local segments = {}
    for s in path:gmatch("[^%.%/]+") do table.insert(segments, s) end
    for _, root in ipairs({game, ReplicatedStorage, Workspace, StarterPlayer}) do
        local cur, ok = root, true
        for _, seg in ipairs(segments) do
            local nxt = cur:FindFirstChild(seg)
            if not nxt then ok = false; break end
            cur = nxt
        end
        if ok and cur ~= root then return cur end
    end
    local last = segments[#segments]
    if last then return ReplicatedStorage:FindFirstChild(last, true) or Workspace:FindFirstChild(last, true) end
    return nil
end

local function dumpRemotes()
    print("=== [GAG2] Remote dump ===")
    local count = 0
    for _, root in ipairs({ReplicatedStorage, Workspace, StarterPlayer, LocalPlayer}) do
        for _, d in ipairs(root:GetDescendants()) do
            if d:IsA("RemoteEvent") or d:IsA("RemoteFunction") then
                print(("[%s]  %s"):format(d.ClassName, d:GetFullName()))
                count = count + 1
            end
        end
    end
    print(("=== %d remotes ==="):format(count))
end

local function fireSellNPC(choiceIndex)
    local ok = pcall(function()
        local mod = StarterPlayer.StarterPlayerScripts
            and StarterPlayer.StarterPlayerScripts:FindFirstChild("Controllers")
            and StarterPlayer.StarterPlayerScripts.Controllers:FindFirstChild("NPCController")
            and StarterPlayer.StarterPlayerScripts.Controllers.NPCController:FindFirstChild("Sell_Steven")
        if mod then
            local m = require(mod)
            if type(m) == "table" then
                for _, fname in ipairs({"SellInventory","Sell","OnDialog","Choose","PickOption"}) do
                    if type(m[fname]) == "function" then m[fname](choiceIndex or 1); return end
                end
            end
        end
    end)
    if ok then return true end
    for _, d in ipairs(Workspace:GetDescendants()) do
        if d:IsA("ProximityPrompt") then
            local nm = (d.Parent and d.Parent.Name or "").." "..(d.ObjectText or "").." "..(d.ActionText or "")
            if nm:lower():find("sell") or nm:lower():find("steven") then
                pcall(function() fireproximityprompt(d) end)
                return true
            end
        end
    end
    return false
end

local function fireSell(itemName, uuid, category)
    local target = CustomRemote or SellRemote
    if target then
        local ok = pcall(function()
            local args = { itemName, uuid, category }
            if target:IsA("RemoteEvent") then target:FireServer(unpack(args))
            else target:InvokeServer(unpack(args)) end
        end)
        if ok then return true end
    end
    return fireSellNPC(1)
end

local function getInventoryFolders()
    local out = {}
    local function tryAdd(x) if x then table.insert(out, x) end end
    local data = LocalPlayer:FindFirstChild("Data") or LocalPlayer:FindFirstChild("PlayerData")
    if data then tryAdd(data); tryAdd(data:FindFirstChild("Inventory")) end
    tryAdd(LocalPlayer:FindFirstChild("Backpack"))
    if LocalPlayer.Character then tryAdd(LocalPlayer.Character) end
    tryAdd(LocalPlayer:FindFirstChild("leaderstats"))
    return out
end

local function getItemRarity(item)
    local r = item:GetAttribute("Rarity") or item:GetAttribute("Tier") or item:GetAttribute("rarity")
    if r then return tostring(r) end
    local v = item:FindFirstChild("Rarity")
    if v and v:IsA("StringValue") then return v.Value end
    for _, rar in ipairs(RARITIES) do
        if rar ~= "Any" and item.Name:lower():find(rar:lower()) then return rar end
    end
    return "Common"
end

local function getItemUUID(item)
    return item:GetAttribute("UUID") or item:GetAttribute("Id") or item:GetAttribute("UID")
        or item:GetAttribute("Guid") or item.Name
end

local function classifyItem(item)
    local nm = item.Name:lower()
    local cat = item:GetAttribute("Category") or item:GetAttribute("Type") or item:GetAttribute("ItemType")
    if cat then
        cat = tostring(cat):lower()
        if cat:find("seed") then return "Seeds" end
        if cat:find("pet")  then return "Pets"  end
    end
    if nm:find("seed") then return "Seeds" end
    if nm:find("pet")  then return "Pets"  end
    return nil
end

local function scanInventory(category)
    local list, seen = {}, {}
    for _, folder in ipairs(getInventoryFolders()) do
        for _, item in ipairs(folder:GetDescendants()) do
            if item:IsA("Tool") or item:IsA("Folder") or item:IsA("StringValue")
                or item:IsA("IntValue") or item:IsA("NumberValue") or item:IsA("Model") then
                local belongs = false
                if folder.Name == category then belongs = true
                else local c = classifyItem(item); if c == category then belongs = true end end
                if belongs and not seen[item] then
                    seen[item] = true
                    local count = item:GetAttribute("Count") or item:GetAttribute("Amount")
                        or (item:IsA("IntValue") and item.Value) or 1
                    table.insert(list, {
                        name = item:GetAttribute("ItemName") or item.Name,
                        rarity = getItemRarity(item), uuid = getItemUUID(item),
                        count = count, instance = item,
                    })
                end
            end
        end
    end
    return list
end

