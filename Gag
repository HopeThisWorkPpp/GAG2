refreshList = function()
    for _, c in ipairs(ItemList:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
    end
    local list = scanInventory(CurrentTab)
    local seen, uniq = {}, {}
    for _, it in ipairs(list) do
        local k = it.name .. "|" .. it.rarity
        if not seen[k] then seen[k] = true; table.insert(uniq, it) end
    end
    local search = SearchBox.Text:lower()
    for _, it in ipairs(uniq) do
        local matchSearch = search == "" or it.name:lower():find(search, 1, true)
        local matchRarity = RarityFilter == "Any" or it.rarity == RarityFilter
        if matchSearch and matchRarity then makeRow(it) end
    end
    ItemList.CanvasSize = UDim2.new(0,0,0, listLayout.AbsoluteContentSize.Y + 12)
    if #uniq == 0 then
        newInst("TextLabel", { Size = UDim2.new(1, -12, 0, 60), BackgroundTransparency = 1,
            Text = "No "..CurrentTab:lower().." found. Click 'Refresh' or use 'Sell via NPC'.",
            Font = Enum.Font.Gotham, TextSize = 13, TextColor3 = Color3.fromRGB(180,180,180),
            TextWrapped = true, Parent = ItemList })
    end
end

