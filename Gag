refreshList = function()
    for _, c in ipairs(ItemList:GetChildren()) do
        if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
    end
    local list = scanInventory(CurrentTab)
    local seen, uniq = {}, {}
    for _, it in ipairs(list) do
        local k = it.name .. "|" .. it.rarity
        if not seen[k] then
            seen[k] = true
            table.insert(uniq, it)
        end
    end
    local search = SearchBox.Text:lower()
    for _, it in ipairs(uniq) do
        local matchSearch = search == "" or it.name:lower():find(search, 1, true)
        local matchRarity = RarityFilter == "Any" or it.rarity == RarityFilter
        if matchSearch and matchRarity then
            makeRow(it)
        end
    end
    ItemList.CanvasSize = UDim2.new(0,0,0, listLayout.AbsoluteContentSize.Y + 12)
    if #uniq == 0 then
        newInst("TextLabel", {
            Size = UDim2.new(1, -12, 0, 60),
            BackgroundTransparency = 1,
            Text = "No " .. CurrentTab:lower() .. " found in your inventory.",
            Font = Enum.Font.Gotham,
            TextSize = 13,
            TextColor3 = Color3.fromRGB(180,180,180),
            Parent = ItemList,
        })
    end
end

SearchBox:GetPropertyChangedSignal("Text"):Connect(refreshList)
RefreshBtn.MouseButton1Click:Connect(refreshList)

-- ========================== SELL LOGIC ==========================
local function performSell(verbose)
    local total, sold, failed = 0, 0, 0
    local list = scanInventory(CurrentTab)
    for _, it in ipairs(list) do
        local key = it.name .. "|" .. it.rarity
        local pass = Selected[CurrentTab][key] == true
        if pass and (RarityFilter == "Any" or it.rarity == RarityFilter) then
            total = total + 1
            local ok = fireSell(it.name, it.uuid, CurrentTab)
            if ok then sold = sold + 1 else failed = failed + 1 end
            task.wait(0.08)
        end
    end
    if verbose then
        setStatus(("Sold %d/%d (%s failed)"):format(sold, total, failed), failed == 0)
    end
    return sold
end

SellNow.MouseButton1Click:Connect(function()
    if not SellRemote then
        setStatus("No sell remote found", false); return
    end
    setStatus("Selling...", true)
    task.spawn(function() performSell(true) end)
end)

