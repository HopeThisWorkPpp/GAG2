local function findMailboxPrompt()
	local gardens = Workspace:FindFirstChild("Gardens")
	if gardens then
		for _,plot in ipairs(gardens:GetChildren()) do
			local signs = plot:FindFirstChild("Signs")
			if signs then
				for _,mbName in ipairs({"GreyMailBox","MailBox","Mailbox"}) do
					local mb = signs:FindFirstChild(mbName)
					if mb then
						local part = mb:FindFirstChild("ProximityPromptPart") or mb.PrimaryPart
						if part then
							local pr = part:FindFirstChild("MailboxPrompt") or part:FindFirstChildOfClass("ProximityPrompt")
							if pr then return pr end
						end
					end
				end
			end
		end
	end
	for _,d in ipairs(Workspace:GetDescendants()) do
		if d:IsA("ProximityPrompt") and (tostring(d.Name)..tostring(d.ActionText)..tostring(d.ObjectText)):lower():find("mail") then
			return d
		end
	end
end

local function openMailbox()
	if Mail.ui and Mail.ui.Parent then return Mail.ui end
	local old=PlayerGui:FindFirstChild("MailboxUI")
	if old then
		local c=old:FindFirstChild("CloseButton",true)
		if c then pcall(function() if firesignal then firesignal(c.MouseButton1Click) end end) end
		task.wait(0.1)
	end
	local prompt=findMailboxPrompt(); if not prompt then return nil,"Mailbox prompt not found" end
	pcall(function() fireproximityprompt(prompt) end); task.wait(0.4)
	local ui=PlayerGui:WaitForChild("MailboxUI",5); if not ui then return nil,"MailboxUI didn't open" end
	local f=ui:WaitForChild("Frame",5); if not f then return nil,"MailboxUI.Frame missing" end
	Mail.ui=ui
	Mail.sendingFrame = f:WaitForChild("SendingFrame",5)
	return ui
end

local function pickRecipient(username)
	username = tostring(username or ""):gsub("^@",""):gsub("^%s+",""):gsub("%s+$","")
	if username=="" then return false,"Empty recipient" end
	local sel = Mail.sendingFrame and Mail.sendingFrame:WaitForChild("SelectPlayerFrame",5)
	if not sel then return false,"SelectPlayerFrame missing" end
	local topbar=sel:WaitForChild("Topbar",5); local searchBox=topbar and topbar:WaitForChild("SearchBox",5)
	if not searchBox then return false,"SearchBox missing" end
	pcall(function() searchBox:CaptureFocus() end); searchBox.Text=username; task.wait(0.05)
	pcall(function() searchBox:ReleaseFocus() end); task.wait(0.05)
	pcall(function() VirtualInputManager:SendKeyEvent(true,Enum.KeyCode.Return,false,game) end); task.wait(0.4)
	local list=sel:WaitForChild("PlayerList",5); if not list then return false,"PlayerList missing" end
	local found=false; local deadline=tick()+4
	while not found and tick()<deadline do
		for _,row in ipairs(list:GetChildren()) do
			if row:IsA("Frame") then
				local btn=row:FindFirstChild("Button")
				local lbl=btn and btn:FindFirstChild("PlayerUsername")
				if lbl then
					local clean=lbl.Text:lower():gsub("^@","")
					if clean==username:lower() then clickBtn(btn); found=true; break end
				end
			end
		end
		if not found then task.wait(0.08) end
	end
	if not found then return false,"'"..username.."' not in server" end
	task.wait(0.3)
	Mail.itemSendFrame = Mail.sendingFrame:WaitForChild("ItemSendFrame",5)
	local scrolls = Mail.itemSendFrame and Mail.itemSendFrame:WaitForChild("ScrollingFrames",5)
	Mail.inventoryFrame = scrolls and scrolls:WaitForChild("InventoryFrame",5)
	if not Mail.inventoryFrame then return false,"InventoryFrame missing" end
	Mail.recipientLocked=true; Mail.recipient=username
	return true,"Connected to "..username
end

local function readInventory()
	local out = { Seeds={}, Pets={}, Crates={}, Gears={} }
	if not Mail.inventoryFrame or not Mail.inventoryFrame.Parent then return out end

	local function readCount(itemFrame)
		local lbl = itemFrame:FindFirstChild("Count",true) or itemFrame:FindFirstChild("Amount",true)
		if lbl and lbl:IsA("TextLabel") then
			local n = tonumber(lbl.Text:match("%d+"))
			if n then return n end
		end
		return nil
	end

	for _,child in ipairs(Mail.inventoryFrame:GetChildren()) do
		local cname = child.Name
		if cname:sub(1,#INV_PREFIX.Seeds) == INV_PREFIX.Seeds then
			table.insert(out.Seeds, { name=cname:sub(#INV_PREFIX.Seeds+1), frame=child, count=readCount(child) })
		elseif cname:sub(1,#INV_PREFIX.Pets) == INV_PREFIX.Pets then
			table.insert(out.Pets, { name=cname:sub(#INV_PREFIX.Pets+1), frame=child, count=readCount(child) })
		elseif cname:sub(1,#INV_PREFIX.Crates) == INV_PREFIX.Crates then
			table.insert(out.Crates, { name=cname:sub(#INV_PREFIX.Crates+1), frame=child, count=readCount(child) })
		else
			for _,gp in ipairs(GEAR_PREFIXES) do
				if cname:sub(1,#gp) == gp then
					table.insert(out.Gears, { name=cname:sub(#gp+1), frame=child, count=readCount(child) })
					break
				end
			end
		end
	end
	for _,bucket in pairs(out) do table.sort(bucket, function(a,b) return a.name<b.name end) end
	return out
end

local function clickInventoryItem(itemFrame)
	if not itemFrame or not itemFrame.Parent then return false end
	-- Find the best GuiButton inside the item (scored by name + size)
	local candidates = {}
	for _,d in ipairs(itemFrame:GetDescendants()) do
		if d:IsA("GuiButton") and d.Visible and d.AbsoluteSize.X > 0 and d.AbsoluteSize.Y > 0 then
			table.insert(candidates, d)
		end
	end
	if #candidates == 0 then
		if itemFrame:IsA("GuiButton") then clickBtn(itemFrame); return true end
		return false
	end
	local function score(b)
		local n = tostring(b.Name):lower()
		if n == "button" or n == "itembutton" or n == "addbutton" or n == "selectbutton" then return 100 end
		if n:find("add") or n:find("select") or n:find("mail") then return 80 end
		if n:find("button") then return 60 end
		return math.floor(b.AbsoluteSize.X * b.AbsoluteSize.Y / 100)
	end
	table.sort(candidates, function(a,b) return score(a) > score(b) end)
	clickBtn(candidates[1])
	return true
end

local function sendMailPlan(plan)
	if not Mail.inventoryFrame then return false,"Mailbox not connected" end
	local total,clicked = 0,0
	for _,p in ipairs(plan) do total = total + p.count end
	if total==0 then return false,"Pick at least one amount > 0" end
	-- Hide our overlay so the virtual mouse click reaches MailboxUI underneath
	local prevEnabled = Gui.Enabled
	Gui.Enabled = false
	task.wait(0.05)
	for _,p in ipairs(plan) do
		for i=1,p.count do
			if not p.entry.frame.Parent then break end
			if not clickInventoryItem(p.entry.frame) then break end
			clicked = clicked + 1
			task.wait(0.06)
		end
	end
	task.wait(0.4)
	local sendBtn = Mail.itemSendFrame:FindFirstChild("SendButton",true)
	if sendBtn and sendBtn:IsA("GuiButton") then
		clickBtn(sendBtn)
	else
		Gui.Enabled = prevEnabled
		return false,"SendButton missing"
	end
	task.wait(0.25)
	Gui.Enabled = prevEnabled
	return true, ("Sent %d clicks to %s"):format(clicked, Mail.recipient)
end

