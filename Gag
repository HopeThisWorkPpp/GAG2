    "Robin", "Owl", "Monkey"
}

local function normalizeName(s)
    return (tostring(s):lower():gsub("[%s_%-:]", ""))
end

local SEED_SET, PET_SET = {}, {}
for _, n in ipairs(SEEDS_LIST) do SEED_SET[normalizeName(n)] = n end
for _, n in ipairs(PETS_LIST)  do PET_SET[normalizeName(n)]  = n end

local function stripInvPrefix(name)
    local s = tostring(name)
    s = s:gsub("^Inv_Pets:", "")
    s = s:gsub("^Inv_Seeds:", "")
    s = s:gsub("^Inv_Crates:", "")
    s = s:gsub("^Inv_Mushrooms:", "")
    s = s:gsub("^Inv_Sprinklers:", "")
    s = s:gsub("^Inv_WateringCans:", "")
    return s
end

local function categorizeItem(rawName)
    local clean = stripInvPrefix(rawName)
    local key = normalizeName(clean)
    local low = tostring(rawName):lower()
    if low:sub(1,9)  == "inv_pets:"  then return "Pets",  clean end
    if low:sub(1,10) == "inv_seeds:" then return "Seeds", clean end
    if PET_SET[key]  then return "Pets",  PET_SET[key]  end
    if SEED_SET[key] then return "Seeds", SEED_SET[key] end
    return nil
end

-- ============ HELPERS ============
local function getSellPrompt()
    local npcs = Workspace:FindFirstChild("NPCS") or Workspace:FindFirstChild("NPCs")
    if not npcs then return nil end
    local steven = npcs:FindFirstChild(CFG.NPCName)
    if not steven then return nil end
    local hrp = steven:FindFirstChild("HumanoidRootPart") or steven.PrimaryPart
    if not hrp then return nil end
    return hrp:FindFirstChildOfClass("ProximityPrompt"), hrp
end

local function scanTools(category)
    local list = {}
    local sources = { LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character }
    local seen = {}
    for _, src in ipairs(sources) do
        if src then
            for _, t in ipairs(src:GetChildren()) do
                if t:IsA("Tool") then
                    local cat, displayName = categorizeItem(t.Name)
                    if not cat then
                        local attrCat = tostring(t:GetAttribute("Category") or t:GetAttribute("Type") or ""):lower()
                        if attrCat:find("pet")  then cat = "Pets"  end
                        if attrCat:find("seed") then cat = "Seeds" end
                        if cat then displayName = stripInvPrefix(t:GetAttribute("ItemName") or t.Name) end
                    end
                    if cat == category then
                        local rarity = t:GetAttribute("Rarity") or t:GetAttribute("Tier") or "Common"
                        local key = (displayName or t.Name) .. "|" .. tostring(rarity)
                        if not seen[key] then
                            seen[key] = true
                            table.insert(list, {
                                name   = displayName or t.Name,
                                rarity = tostring(rarity),
                                tool   = t,
                            })
                        end
                    end
                end
            end
        end
    end

    local prefix = (category == "Pets") and "Inv_Pets:" or "Inv_Seeds:"
    for _, gui in ipairs(PlayerGui:GetDescendants()) do
        local nm = gui.Name
        if type(nm) == "string" and nm:sub(1, #prefix) == prefix then
            local clean = nm:sub(#prefix + 1)
            local rarity = gui:GetAttribute("Rarity") or gui:GetAttribute("Tier") or "Common"
            local key = clean .. "|" .. tostring(rarity)
            if not seen[key] then
                seen[key] = true
                table.insert(list, {
                    name    = clean,
                    rarity  = tostring(rarity),
                    tool    = nil,
                    uiFrame = gui,
                })
            end
        end
    end

    return list
end

local function equipTool(tool)
    if not tool then return end
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then pcall(function() hum:EquipTool(tool) end) end
end

local function clickDialogButton(textMatch)
    for _, g in ipairs(PlayerGui:GetDescendants()) do
        if g:IsA("TextButton") and g.Visible then
            local t = (g.Text or ""):lower()
            if t:find(textMatch:lower(), 1, true) then
                pcall(function() g.MouseButton1Click:Fire() end)
                return true
            end
        end
    end
    return false
end

local origCFrame = nil
local function teleportToSteven()
    local _, hrp = getSellPrompt()
    if not hrp then return false end
    local char = LocalPlayer.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return false end
    origCFrame = myHRP.CFrame
    myHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, 4)
    return true
end

local function returnHome()
    if not origCFrame then return end
    local char = LocalPlayer.Character
    local myHRP = char and char:FindFirstChild("HumanoidRootPart")
    if myHRP then myHRP.CFrame = origCFrame end
    origCFrame = nil
end

local function talkToSteven()
    local prompt = getSellPrompt()
    if not prompt then return false, "No Steven prompt" end
    local ok = pcall(function() fireproximityprompt(prompt) end)
    return ok, ok and "Triggered prompt" or "fireproximityprompt blocked"
end

local function sellInventoryViaNPC()
    local needTP = true
    do local _, hrp = getSellPrompt()
       local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
       if hrp and myHRP and (hrp.Position - myHRP.Position).Magnitude < 8 then needTP = false end
    end
    if needTP then teleportToSteven(); task.wait(0.4) end
    talkToSteven(); task.wait(0.5)
    local ok = clickDialogButton("Sell Inventory")
    task.wait(0.3)
    if CFG.TeleportBack and needTP then returnHome() end
    return ok
end

local function sellOneTool(tool)
    if not tool then return false end
    local needTP = true
    do local _, hrp = getSellPrompt()
       local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
       if hrp and myHRP and (hrp.Position - myHRP.Position).Magnitude < 8 then needTP = false end
    end
    if needTP then teleportToSteven(); task.wait(0.4) end
    equipTool(tool); task.wait(0.3)
    talkToSteven(); task.wait(0.5)
    local ok = clickDialogButton("Sell This")
    task.wait(0.3)
    if CFG.TeleportBack and needTP then returnHome() end
    return ok
end

